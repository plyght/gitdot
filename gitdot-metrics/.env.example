RUST_LOG=debug

# Metrics server port
PORT=8083

# Vercel OIDC issuer URL (used to gate all metrics endpoints against direct external calls)
VERCEL_OIDC_URL=https://oidc.vercel.com/[TEAM_ID]

# Ed25519 public key for verifying user JWTs issued by gitdot-auth
GITDOT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
...
-----END PUBLIC KEY-----"

# Gitdot URLs
GITDOT_WEB_URL=http://localhost:3000
