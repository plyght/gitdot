RUST_LOG=debug

# Auth server port
PORT=8082

# Posgres direct connection URI
DATABASE_URL=postgres://[USERNAME_HERE]:[PASSWORD_HERE]@host:5432/[DATABASE_HERE]

# Ed25519 keypair for signing JWTs
# Generate with: just generate-keys
# In production, inject from secret manager
GITDOT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
...
-----END PUBLIC KEY-----"
GITDOT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
...
-----END PRIVATE KEY-----"

# HMAC shared secret with the gitdot slack bot server
GITDOT_SLACK_SECRET=

# HMAC shared secret for verifying GitHub webhook deliveries
# Must match the signing secret registered against the gitdot GitHub App
GITDOT_GITHUB_SECRET=

# Gitdot URLs
GITDOT_WEB_URL=http://localhost:3000
GITDOT_SLACK_BOT_SERVER_URL=http://localhost:3001
GITDOT_OAUTH_DEVICE_VERIFICATION_URI=http://localhost:3000/oauth/device
GITDOT_REDIS_URL=redis://localhost:6379

# GitHub App credentials (for OAuth + repo migration)
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
...
-----END RSA PRIVATE KEY-----"
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Cloudflare R2 (avatar uploads)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=

# Resend (transactional email)
RESEND_API_KEY=
